UNITS LENGTH=A TIME=0.001  #Amstroeng, hartree, fs
#RESTART

dis-oo: DISTANCE ATOMS=39,41
#cn-oo: COORDINATION GROUPA=56 GROUPB=57 R_0=1.3 D_0=0.7 NN=12 MM=24
#cn-ago: COORDINATION GROUPA=136-170 GROUPB=1-135 R_0=3 NN=18 MM=36

metad: METAD ARG=dis-oo SIGMA=0.1 HEIGHT=5 BIASFACTOR=@BIASFACTOR TEMP=@TEMP PACE=100
uwalls: UPPER_WALLS ARG=dis-oo AT=6 KAPPA=300 EXP=2

PRINT STRIDE=100 ARG=dis-oo,metad.bias  FILE=COLVAR

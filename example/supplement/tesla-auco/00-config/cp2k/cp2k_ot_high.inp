&GLOBAL
    PROJECT AI2KIT
    RUN_TYPE ENERGY_FORCE
&END GLOBAL
&FORCE_EVAL
    METHOD QS
    STRESS_TENSOR ANALYTICAL
    &DFT
        BASIS_SET_FILE_NAME /public/home/mljia12/resources/cp2k/BASIS_MOLOPT
        POTENTIAL_FILE_NAME /public/home/mljia12/resources/cp2k/GTH_POTENTIALS
        CHARGE              0
        UKS                 T
        &MGRID
            CUTOFF     800
            REL_CUTOFF 90
            NGRIDS     4
        &END MGRID
        &QS
            EPS_DEFAULT 1.0E-12
        &END QS
        # CONFIGURATION FOR SEMICONDUCTOR
        &SCF
            SCF_GUESS RESTART
            EPS_SCF 1e-06
            MAX_SCF 50
            &OUTER_SCF
                EPS_SCF 1e-06
                MAX_SCF 4
            &END OUTER_SCF
            &OT
                MINIMIZER CG
                PRECONDITIONER FULL_SINGLE_INVERSE
                ENERGY_GAP 0.1
            &END OT
        &END SCF
        # END CONFIGURATION FOR SEMICONDUCTOR
        &XC
            &XC_FUNCTIONAL PBE
            &END XC_FUNCTIONAL
            &vdW_POTENTIAL
                DISPERSION_FUNCTIONAL PAIR_POTENTIAL
                &PAIR_POTENTIAL
                    TYPE DFTD3
                    PARAMETER_FILE_NAME /public/home/mljia12/resources/cp2k/dftd3.dat
                    REFERENCE_FUNCTIONAL PBE
                &END PAIR_POTENTIAL
            &END vdW_POTENTIAL
        &END XC
    &END DFT
    &SUBSYS
    @include coord_n_cell.inc
    &KIND Au
        BASIS_SET TZV2P-MOLOPT-SR-GTH
        POTENTIAL GTH-PBE-q11
    &END KIND
    &KIND Ag
        BASIS_SET TZV2P-MOLOPT-SR-GTH
        POTENTIAL GTH-PBE-q11
    &END KIND
    &KIND Cu
        BASIS_SET TZV2P-MOLOPT-SR-GTH
        POTENTIAL GTH-PBE-q11
    &END KIND
    &KIND Pt
        BASIS_SET TZV2P-MOLOPT-SR-GTH
        POTENTIAL GTH-PBE-q18
    &END KIND
    &KIND Pd
        BASIS_SET TZV2P-MOLOPT-PBE-GTH-q18
        POTENTIAL GTH-PBE-q18
    &END KIND
    &KIND Ni
        BASIS_SET TZV2P-MOLOPT-PBE-GTH-q18
        POTENTIAL GTH-PBE-q18
    &END KIND
    &KIND C
        BASIS_SET TZV2P-MOLOPT-GTH
        POTENTIAL GTH-PBE-q4
    &END KIND
    &KIND H
        BASIS_SET TZV2P-MOLOPT-GTH
        POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND O
        BASIS_SET TZV2P-MOLOPT-GTH
        POTENTIAL GTH-PBE-q6
    &END KIND

    &END SUBSYS
    &PRINT
        &FORCES ON
        &END FORCES
    &END PRINT
&END FORCE_EVAL
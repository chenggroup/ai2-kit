{
  "model": {
    "descriptor": {
      "type": "se_a",
      "sel": [
        45,
        80
      ],
      "rcut_smth": 0.5,
      "rcut": 6.0,
      "neuron": [
        25,
        50,
        100
      ],
      "resnet_dt": false,
      "axis_neuron": 16,
      "seed": @SEED
    },
    "fitting_net": {
      "neuron": [
        240,
        240,
        240
      ],
      "resnet_dt": true,
      "seed": @SEED
    },
    "type_map": [
      "O",
      "H"
    ]
  },
  "learning_rate": {
    "type": "exp",
    "start_lr": 0.001,
    "decay_steps": @DECAY_STEPS
  },
  "loss": {
    "start_pref_e": 0.02,
    "limit_pref_e": 1,
    "start_pref_f": 1000,
    "limit_pref_f": 1,
    "start_pref_v": 0,
    "limit_pref_v": 0
  },
  "training": {
    "numb_steps": @TRAIN_STEPS,
    "seed": @SEED,
    "disp_file": "lcurve.out",
    "numb_test": 10,
    "disp_freq": 100,
    "save_freq": 1000,
    "save_ckpt": "model.ckpt",
    "disp_training": true,
    "time_training": true,
    "profiling": false,
    "profiling_file": "timeline.json",
    "training_data": {
      "set_prefix": "set",
      "batch_size": "auto",
      "sys_probs": null,
      "systems": [
        @DP_DATASET
      ],
      "auto_prob_style": "prob_sys_size"
    }
  }
}
